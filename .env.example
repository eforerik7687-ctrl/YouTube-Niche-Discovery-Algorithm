# YouTube Niche Finder Configuration
# Proxy (optional, YouTube may block some regions)
PROXY=

# Default seed keywords (comma-separated)
SEED_KEYWORDS=python tutorial, machine learning, data science

# Time window days
RECENT_WINDOW=7
MEDIUM_WINDOW=30
PAST_WINDOW=365

# Search configuration
MAX_RESULTS_PER_KEYWORD=200
SORT_BY=upload_date

# Output directories
OUTPUT_DIR=output
RAW_DIR=output/raw
