# YouTube Niche Finder Configuration
# Proxy (optional, YouTube may block some regions)
PROXY=

# Proxy rotation list (comma-separated, optional)
PROXY_LIST=

# Anti-ban: random delay (seconds) before each YouTube search
DELAY_MIN=0.3
DELAY_MAX=0.7

# Default seed keywords (comma-separated)
SEED_KEYWORDS=

# Time window days
RECENT_WINDOW=7
MEDIUM_WINDOW=30
PAST_WINDOW=365

# Search configuration
MAX_RESULTS_PER_KEYWORD=200
SORT_BY=upload_date

# Output directories
OUTPUT_DIR=output
RAW_DIR=output/raw
